# ============================================================
# Full-Stack Dev Box — environment variables
# Copy to .env and fill in your values
# ============================================================

# ── Auth gateway password ────────────────────────────────────
PASSWORD=devbox

# ── Claude Code auth (choose one) ───────────────────────────
# Option A — API key (pay-per-use):
ANTHROPIC_API_KEY=sk-ant-api03-...your-key-here...
# Option B — Subscription (Pro/Max/Team): leave key empty,
#            then run `claude login` inside the container terminal

# ── API base URL ─────────────────────────────────────────────
# Leave empty to use real api.anthropic.com (works with both options above)
# Set to a proxy URL only if you know what you're doing
ANTHROPIC_BASE_URL=

# ── Ports ────────────────────────────────────────────────────
PORT=8080
APP_PORT=8090
DEBUG_PORT=5005

# ── Git identity ─────────────────────────────────────────────
GIT_NAME=Your Name
GIT_EMAIL=you@example.com

# ── GitHub (optional — for MCP GitHub server) ────────────────
GITHUB_TOKEN=

# ── SSH keys dir (mounted read-only for git push) ────────────
SSH_DIR=~/.ssh

# ── Timezone ─────────────────────────────────────────────────
TZ=Europe/Moscow
